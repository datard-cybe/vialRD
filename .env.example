# ===============================================
# VialRD — Variables de entorno
# Copia este archivo a .env y rellena los valores
# NUNCA commitear el .env real al repo
# ===============================================

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_NEVER_PUSH_TO_FRONTEND

# OpenRouteService (https://openrouteservice.org/dev/#/signup)
ORS_API_KEY=YOUR_ORS_API_KEY

# hCaptcha (https://www.hcaptcha.com/)
HCAPTCHA_SITEKEY=YOUR_HCAPTCHA_SITEKEY
HCAPTCHA_SECRET=YOUR_HCAPTCHA_SECRET

# Mapbox (opcional, solo si quieres tiles más bonitos que OSM raster)
# Tier gratis: 50,000 cargas/mes
MAPBOX_TOKEN=

# Stadia Maps (alternativa, opcional)
# Tier gratis: 200,000 tiles/mes
STADIA_API_KEY=

# Para el ETL de Python (datos.gob.do)
DATOS_GOB_DO_API_BASE=https://datos.gob.do/api/3/action

# Cloudflare (deploy)
CF_PAGES_PROJECT=vialrd
CF_ACCOUNT_ID=
